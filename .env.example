# DashScope (Alibaba Cloud Qwen) — get your key at https://modelstudio.console.alibabacloud.com
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# OpenAI-compatible base URL. International/Singapore endpoint:
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Text model (chat, scheme matching)
QWEN_MODEL=qwen3.7-max-2026-05-20

# Vision model (photo reports, document reading)
QWEN_VL_MODEL=qwen-vl-max

# DashScope (Alibaba Cloud Qwen) — get your key at https://modelstudio.console.alibabacloud.com
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# OpenAI-compatible base URL. International/Singapore endpoint:
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Text model (chat, scheme matching)
QWEN_MODEL=qwen3.7-max-2026-05-20

# Vision model (photo reports, document reading)
QWEN_VL_MODEL=qwen-vl-max

# --- OPTIONAL: Firebase (Google sign-in + complaint cloud sync) ---
# Leave these blank to run the app fully without login. If set, an optional
# "Sign in" button appears and complaints sync to the user's account.
# Get them from Firebase Console → Project settings → Your apps → Web app config.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

